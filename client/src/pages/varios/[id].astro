---
// src/pages/varios/[id].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { varios, getVariosById } from '../../data/varios';

export function getStaticPaths() {
  return varios
    .flatMap((sec) => sec.items)
    .map((item) => ({
      params: { id: String(item.id) },
      props:  { item },
    }));
}

const { item } = Astro.props;

const statusLabel = {
  completed: { text: 'Completado', class: 'status-completed' },
  upcoming:  { text: 'Próximamente', class: 'status-upcoming' },
};
const st = statusLabel[item.status];
---

<BaseLayout title={`${item.title} — Ania Starlight`}>
  <div class="detail-page">

    <!-- ── HERO ── -->
    <div class="anime-hero">
      {item.coverImage && (
        <div class="anime-hero-bg" style={`background-image: url(${item.coverImage})`}></div>
      )}
      <div class="anime-hero-overlay"></div>

      <div class="container anime-hero-content">
        <a href="/varios" class="back-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M5 12l7-7M5 12l7 7"/>
          </svg>
          Volver a Animes Varios
        </a>

        <div class="anime-hero-grid">
          <!-- Portada -->
          <div class="anime-cover-wrap">
            <div class="anime-cover">
              {item.image
                ? <img src={item.image} alt={item.title} />
                : <span class="cover-emoji">{item.emoji}</span>
              }
              <div class="cover-glow"></div>
            </div>
          </div>

          <!-- Info -->
          <div class="anime-info">
            <div class="anime-meta-top">
              <span class={`anime-status ${st.class}`}>{st.text}</span>
              <span class="anime-genre">{item.genre}</span>
            </div>

            <h1 class="anime-title">{item.title}</h1>

            {item.description && (
              <p class="anime-desc">{item.description}</p>
            )}

            <div class="anime-stats">
              <div class="astat">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--pink)" stroke-width="2">
                  <rect x="2" y="7" width="20" height="14" rx="2"/>
                  <path d="M16 7V5a2 2 0 0 0-4 0v2M8 7V5a2 2 0 0 0-4 0v2"/>
                </svg>
                <div>
                  <span class="astat-num">{item.episodes.length}</span>
                  <span class="astat-lbl">Total episodios</span>
                </div>
              </div>

              <!-- Link externo -->
              <a href={item.url} target="_blank" rel="noopener" class="astat astat-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--cyan)" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15,3 21,3 21,9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                <div>
                  <span class="astat-num" style="font-size:1rem">{item.urlLabel}</span>
                  <span class="astat-lbl">Ver serie completa</span>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── EPISODIOS ── -->
    <section class="episodes-section">
      <div class="container">
        <div class="ep-section-header">
          <h2 class="ep-section-title">
            <span class="ep-title-bar"></span>
            EPISODIOS
          </h2>
        </div>

        {item.episodes.length > 0 ? (
          <div class="ep-grid">
            {item.episodes.map((ep, i) => (
              <a href={ep.url} target="_blank" rel="noopener" class="ep-card">
                <div class="ep-thumb">
                  {ep.thumbnail
                    ? <img src={ep.thumbnail} alt={ep.label} />
                    : <div class="ep-thumb-placeholder">
                        <span class="ep-num-big">{String(i + 1).padStart(2, '0')}</span>
                      </div>
                  }
                  <div class="ep-thumb-overlay">
                    <div class="play-circle">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
                        <polygon points="5,3 19,12 5,21"/>
                      </svg>
                    </div>
                  </div>
                  {ep.duration && <span class="ep-duration">{ep.duration}</span>}
                </div>
                <div class="ep-info">
                  <div class="ep-label-row">
                    <span class="ep-badge">{ep.num}</span>
                    {ep.isNew && <span class="ep-new">NUEVO</span>}
                  </div>
                  <h3 class="ep-title">{ep.label}</h3>
                  {ep.date && <span class="ep-date">{ep.date}</span>}
                </div>
                <div class="ep-arrow">↗</div>
              </a>
            ))}
          </div>
        ) : (
          <div class="no-episodes">
            <span>⏳</span>
            <p>Próximamente — aún no hay episodios cargados.</p>
            <a href={item.url} target="_blank" rel="noopener" class="btn btn-cyan" style="margin-top:8px">
              {item.urlLabel} ↗
            </a>
          </div>
        )}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Reutiliza exactamente los mismos estilos que temporada/[id].astro */
  .detail-page { min-height: 100vh; padding-top: var(--nav-h); }

  .anime-hero {
    position: relative; overflow: hidden;
    padding: 60px 0 48px; min-height: 360px;
    display: flex; align-items: flex-end;
  }
  .anime-hero-bg {
    position: absolute; inset: 0;
    background-size: cover; background-position: center top;
    filter: blur(18px) brightness(.35) saturate(1.4);
    transform: scale(1.1);
  }
  .anime-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(4,6,14,.4) 0%, rgba(4,6,14,.7) 60%, var(--dark) 100%);
  }
  .anime-hero-content { position: relative; z-index: 2; width: 100%; }

  .back-btn {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'Orbitron', sans-serif; font-size: .68rem;
    letter-spacing: .15em; color: var(--text-dim);
    margin-bottom: 32px; transition: color .2s; text-transform: uppercase;
  }
  .back-btn:hover { color: var(--cyan); }

  .anime-hero-grid {
    display: grid; grid-template-columns: 220px 1fr;
    gap: 40px; align-items: flex-end;
  }
  .anime-cover {
    width: 220px; aspect-ratio: .68;
    border-radius: 12px; overflow: hidden;
    border: 2px solid var(--border-p);
    position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,.6), var(--glow-p);
  }
  .anime-cover img { width: 100%; height: 100%; object-fit: cover; }
  .cover-emoji {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 5rem; opacity: .4;
    background: linear-gradient(135deg, rgba(255,45,138,.06), rgba(212,0,255,.06));
  }
  .cover-glow {
    position: absolute; bottom: -20px; left: 50%;
    transform: translateX(-50%);
    width: 80%; height: 40px;
    background: radial-gradient(ellipse, rgba(255,45,138,.3), transparent 70%);
    filter: blur(12px); pointer-events: none;
  }

  .anime-meta-top { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; }
  .anime-genre { font-family: 'Orbitron', sans-serif; font-size: .65rem; letter-spacing: .2em; color: var(--text-dim); text-transform: uppercase; }
  .anime-title { font-family: 'Orbitron', sans-serif; font-size: clamp(1.8rem, 3.5vw, 3rem); font-weight: 900; color: #fff; line-height: 1.1; margin-bottom: 20px; }
  .anime-desc  { font-size: .97rem; color: var(--text-dim); line-height: 1.75; max-width: 560px; margin-bottom: 28px; }

  .anime-stats { display: flex; gap: 16px; flex-wrap: wrap; }
  .astat {
    display: flex; align-items: center; gap: 12px;
    background: rgba(255,45,138,.07); border: 1px solid var(--border-p);
    border-radius: 10px; padding: 14px 20px;
    text-decoration: none; color: var(--text);
  }
  .astat-link { transition: border-color .2s, box-shadow .2s; cursor: pointer; }
  .astat-link:hover { border-color: var(--cyan); box-shadow: var(--glow-c); }
  .astat-num { display: block; font-family: 'Orbitron', sans-serif; font-size: 1.6rem; font-weight: 900; color: var(--pink); line-height: 1; }
  .astat-lbl { display: block; font-size: .68rem; letter-spacing: .15em; color: var(--text-dim); text-transform: uppercase; margin-top: 2px; }

  .episodes-section { padding: 48px 0 80px; }
  .ep-section-title { font-family: 'Orbitron', sans-serif; font-size: 1rem; font-weight: 900; letter-spacing: .2em; color: #fff; display: flex; align-items: center; gap: 14px; margin-bottom: 28px; }
  .ep-title-bar { display: block; width: 4px; height: 24px; border-radius: 2px; background: linear-gradient(var(--pink), var(--magenta)); }

  .ep-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .ep-card { display: flex; flex-direction: column; background: var(--card); border: 1px solid var(--border-c); border-radius: var(--radius); overflow: hidden; text-decoration: none; color: var(--text); transition: transform .3s, border-color .3s, box-shadow .3s; position: relative; }
  .ep-card:hover { transform: translateY(-5px); border-color: var(--pink); box-shadow: var(--glow-p); }

  .ep-thumb { aspect-ratio: 16/9; position: relative; overflow: hidden; background: linear-gradient(135deg, rgba(255,45,138,.05), rgba(212,0,255,.05)); }
  .ep-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
  .ep-card:hover .ep-thumb img { transform: scale(1.05); }
  .ep-thumb-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
  .ep-num-big { font-family: 'Orbitron', sans-serif; font-size: 3rem; font-weight: 900; color: rgba(255,45,138,.15); }
  .ep-thumb-overlay { position: absolute; inset: 0; background: rgba(4,6,14,.4); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity .3s; }
  .ep-card:hover .ep-thumb-overlay { opacity: 1; }
  .play-circle { width: 52px; height: 52px; border-radius: 50%; background: rgba(255,45,138,.2); border: 2px solid var(--pink); display: flex; align-items: center; justify-content: center; box-shadow: var(--glow-p); }
  .ep-duration { position: absolute; bottom: 8px; right: 10px; font-family: 'Orbitron', sans-serif; font-size: .6rem; background: rgba(4,6,14,.8); padding: 3px 8px; border-radius: 4px; color: #fff; }

  .ep-info { padding: 14px 16px; flex: 1; }
  .ep-label-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .ep-badge { font-family: 'Orbitron', sans-serif; font-size: .6rem; letter-spacing: .12em; color: var(--pink); background: rgba(255,45,138,.08); border: 1px solid var(--border-p); padding: 2px 8px; border-radius: 4px; }
  .ep-new { font-family: 'Orbitron', sans-serif; font-size: .55rem; letter-spacing: .12em; color: var(--pink); background: rgba(255,45,138,.1); border: 1px solid var(--border-p); padding: 2px 8px; border-radius: 4px; animation: pulse-new 2s ease infinite; }
  @keyframes pulse-new { 0%,100%{opacity:1} 50%{opacity:.5} }
  .ep-title { font-size: .9rem; font-weight: 600; color: #fff; margin-bottom: 4px; }
  .ep-date  { font-size: .72rem; color: var(--text-dim); }
  .ep-arrow { position: absolute; top: 12px; right: 14px; font-size: 1rem; color: var(--text-dim); transition: color .2s, transform .2s; }
  .ep-card:hover .ep-arrow { color: var(--pink); transform: translate(2px, -2px); }

  .no-episodes { display: flex; flex-direction: column; align-items: center; gap: 16px; padding: 60px 0; color: var(--text-dim); text-align: center; }
  .no-episodes span { font-size: 3rem; }

  @media(max-width: 700px) {
    .anime-hero-grid { grid-template-columns: 1fr; }
    .ep-grid { grid-template-columns: 1fr; }
  }
</style>
