  .gallery-overlay { position: absolute; inset: 0; background: rgba(4,6,14,.55); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; opacity: 0; transition: opacity .3s; }
  .gallery-item:hover .gallery-overlay { opacity: 1; }
  .gallery-caption { font-family: 'Orbitron', sans-serif; font-size: .7rem; letter-spacing: .1em; color: #fff; text-align: center; padding: 0 8px; }
  .gallery-play    { display: flex; align-items: center; gap: 8px; font-family: 'Orbitron', sans-serif; font-size: .65rem; letter-spacing: .12em; color: var(--cyan); background: rgba(4,6,14,.7); border: 1px solid rgba(0,245,255,.3); padding: 6px 14px; border-radius: 6px; }
  .bday-gallery .bday-item { border-color: var(--border-p); }
  .bday-gallery .bday-item:hover { box-shadow: var(--glow-p); border-color: var(--pink); }
  .bday-overlay { background: rgba(4,6,14,.6); }
  .bday-play    { color: var(--pink) !important; border-color: rgba(255,45,138,.3) !important; }

  /* ══ VIDEOS ═══════════════════════════════════════════════════════ */
  .videos-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px,1fr)); gap: 20px; }
  .video-card  { background: var(--card); border: 1px solid var(--border-c); border-radius: var(--radius); overflow: hidden; cursor: pointer; transition: transform .3s, border-color .3s, box-shadow .3s; }
  .video-card:hover { transform: translateY(-5px); border-color: var(--pink); box-shadow: var(--glow-p); }
