  .placeholder-hint code { color: var(--cyan); }

  /* ══ DEDICATORIAS ════════════════════════════════════════════════ */
  .dedic-grid { display: flex; flex-direction: column; gap: 20px; }
  .dedic-card      { background: linear-gradient(135deg, rgba(0,245,255,.04), rgba(212,0,255,.04)); border: 1px solid var(--border-c); border-radius: 14px; padding: 24px; display: flex; gap: 16px; align-items: flex-start; position: relative; transition: border-color .3s, box-shadow .3s; animation: fade-up .6s ease both; }
  @keyframes fade-up { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:none} }
  .dedic-card:hover { border-color: rgba(0,245,255,.3); box-shadow: var(--glow-c); }
  .dedic-avatar    { font-size: 1.8rem; flex-shrink: 0; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; background: rgba(0,245,255,.07); border: 1px solid var(--border-c); border-radius: 50%; }
  .dedic-body      { flex: 1; min-width: 0; }
  .dedic-header    { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; flex-wrap: wrap; }
  .dedic-autor     { font-family: 'Orbitron', sans-serif; font-size: .78rem; font-weight: 700; color: #fff; }
  .dedic-rol       { font-family: 'Orbitron', sans-serif; font-size: .6rem; letter-spacing: .1em; color: var(--cyan); background: rgba(0,245,255,.08); border: 1px solid rgba(0,245,255,.2); padding: 2px 8px; border-radius: 4px; }
  .dedic-texto     { font-size: .92rem; line-height: 1.8; color: rgba(255,255,255,.78); font-style: italic; margin: 0; word-break: break-word; white-space: pre-line; }
  /* Botón "Ver más" — estilos base por si el JS inline falla */
  .dedic-toggle    { display: block; margin-top: 10px; background: transparent; border: 1px solid #00f5ff; border-radius: 4px; color: #00f5ff !important; font-family: 'Orbitron', sans-serif; font-size: .65rem; letter-spacing: .12em; cursor: pointer; padding: 4px 12px; text-transform: uppercase; transition: color .2s, border-color .2s; }
  .dedic-toggle:hover { color: #ff2d8a !important; border-color: #ff2d8a; }
  .dedic-deco      { position: absolute; top: 14px; right: 16px; color: var(--pink); opacity: .4; font-size: .9rem; }
  .dedic-empty     { font-size: .85rem; color: var(--text-dim); padding: 16px; background: rgba(0,245,255,.03); border-radius: 8px; border: 1px dashed var(--border-c); }
  .dedic-empty code { color: var(--cyan); }

  /* ══ VIEWER MODAL ════════════════════════════════════════════════ */
  .viewer-overlay { position: fixed; inset: 0; z-index: 3000; background: rgba(4,6,14,.94); backdrop-filter: blur(10px); display: none; align-items: center; justify-content: center; padding: 20px; }
  .viewer-overlay.open { display: flex; }
  .viewer-box { background: var(--dark2); border: 1px solid var(--border-c); border-radius: 14px; width: 100%; max-width: 1000px; max-height: 90vh; overflow: hidden; display: flex; flex-direction: column; animation: modal-in .25s ease both; }
  @keyframes modal-in { from{opacity:0;transform:scale(.95) translateY(20px)} to{opacity:1;transform:none} }
  .viewer-header { display: flex; align-items: center; justify-content: space-between; padding: 12px 18px; border-bottom: 1px solid var(--border-c); background: rgba(0,245,255,.03); flex-shrink: 0; }
  .viewer-title  { font-family: 'Orbitron', sans-serif; font-size: .8rem; letter-spacing: .08em; color: #fff; }
  .viewer-close  { width: 32px; height: 32px; border-radius: 6px; border: 1px solid var(--border-c); color: var(--text-dim); font-size: 1rem; display: flex; align-items: center; justify-content: center; transition: border-color .2s, color .2s; cursor: pointer; background: transparent; flex-shrink: 0; }
  .viewer-close:hover { border-color: var(--pink); color: var(--pink); }
  .viewer-frame-wrap { flex: 1; position: relative; aspect-ratio: 16/9; background: #000; overflow: hidden; }
  .viewer-frame-wrap iframe { width: 100%; height: 100%; border: none; display: block; }

  /* ══ CIERRE ══════════════════════════════════════════════════════ */
  .bday-footer-section { padding: 80px 0; position: relative; z-index: 2; border-top: 1px solid rgba(255,45,138,.15); background: linear-gradient(to bottom, transparent, rgba(212,0,255,.04)); }
  .bday-finale-emoji { font-size: 4rem; margin-bottom: 20px; animation: float-cake 3s ease-in-out infinite; display: block; }
  .bday-finale-title { font-family: 'Orbitron', sans-serif; font-size: clamp(1.2rem,3vw,2rem); font-weight: 900; color: #fff; margin-bottom: 16px; line-height: 1.4; }
  .bday-finale-sub   { font-family: 'Orbitron', sans-serif; font-size: .72rem; letter-spacing: .2em; color: var(--text-dim); }

  /* ══ RESPONSIVE ══════════════════════════════════════════════════ */
  @media(max-width: 768px) {
    .cd-unit { min-width: 65px; padding: 14px 16px; } .cd-num { font-size: 2rem; }
    .gallery-grid { grid-template-columns: repeat(2,1fr); grid-auto-rows: 160px; }
    .gallery-featured { grid-column: span 2; grid-row: span 1; }
    .carta-wrap { padding: 32px 20px; }
  }
  @media(max-width: 480px) {
    .cd-timer { gap: 4px; } .cd-unit { min-width: 56px; padding: 12px; } .cd-sep { font-size: 1.5rem; }
    .gallery-grid { grid-template-columns: 1fr; } .gallery-featured { grid-column: span 1; }
    .viewer-overlay { padding: 8px; }
  }
</style>

<script define:vars={{ BIRTHDAY_ISO }}>
  const targetDate      = new Date(BIRTHDAY_ISO).getTime();
  const countdownScreen = document.getElementById('countdownScreen');
  const bdayContent     = document.getElementById('bdayContent');

  function pad(n) { return String(n).padStart(2, '0'); }

  function tick() {
    const diff = targetDate - Date.now();
    if (diff <= 0) { reveal(); return; }
    document.getElementById('cdDays').textContent  = pad(Math.floor(diff / 86400000));
    document.getElementById('cdHours').textContent = pad(Math.floor((diff % 86400000) / 3600000));
    document.getElementById('cdMins').textContent  = pad(Math.floor((diff % 3600000) / 60000));
    document.getElementById('cdSecs').textContent  = pad(Math.floor((diff % 60000) / 1000));
  }

  function reveal() {
    clearInterval(timer);
    countdownScreen.style.display = 'none';
    bdayContent.style.display = 'block';
    spawnStars('heroStars');
    spawnConfetti();
    initViewer();

    // ── "Ver más" para dedicatorias largas ──────────────────────
    const LONG_THRESHOLD = 520;
    document.querySelectorAll('.dedic-card').forEach(card => {
      const textoEl = card.querySelector('.dedic-texto');
      if (!textoEl) return;
      if ((textoEl.textContent || '').length <= LONG_THRESHOLD) return;

      card.classList.add('dedic-long');
      textoEl.style.cssText = 'max-height:7rem;overflow:hidden;transition:max-height 0.4s ease;font-size:.92rem;line-height:1.8;color:rgba(255,255,255,.78);font-style:italic;margin:0;word-break:break-word;white-space:pre-line;';

      const btn = document.createElement('button');
      btn.className = 'dedic-toggle';
      // Todos los estilos en cssText para máxima especificidad — evita herencia del padre
      btn.style.cssText = 'display:block;margin-top:12px;padding:5px 14px;background:transparent;border:1px solid #00f5ff;border-radius:4px;color:#00f5ff;font-family:Orbitron,sans-serif;font-size:.65rem;letter-spacing:.12em;cursor:pointer;text-transform:uppercase;';
      btn.textContent = 'Ver más ↓';

      let expanded = false;
      btn.addEventListener('click', () => {
        expanded = !expanded;
        textoEl.style.maxHeight = expanded ? textoEl.scrollHeight + 'px' : '7rem';
        btn.textContent = expanded ? 'Ver menos ↑' : 'Ver más ↓';
        btn.style.color = expanded ? '#ff2d8a' : '#00f5ff';
        btn.style.borderColor = expanded ? '#ff2d8a' : '#00f5ff';
      });

      // Append dentro de dedic-body (hermano del texto)
      textoEl.parentElement.appendChild(btn);
    });
  }

  tick();
  const timer = setInterval(tick, 1000);
  document.getElementById('cdUnlockBtn').addEventListener('click', reveal);

  spawnStars('cntStars');

  function spawnStars(id) {
    const el = document.getElementById(id);
    if (!el) return;
    for (let i = 0; i < 60; i++) {
      const s = document.createElement('div');
      const size = Math.random() * 2.5 + 0.5;
      s.style.cssText = `position:absolute;width:${size}px;height:${size}px;border-radius:50%;background:#fff;opacity:${Math.random()*.6+.1};top:${Math.random()*100}%;left:${Math.random()*100}%;animation:twinkle ${Math.random()*3+2}s ease-in-out ${Math.random()*3}s infinite alternate;`;
      el.appendChild(s);
    }
  }

  function spawnConfetti() {
    const container = document.getElementById('confetti');
    const colors = ['#00f5ff','#ff2d8a','#d400ff','#ffffff','#f5c518'];
    for (let i = 0; i < 55; i++) {
      const c = document.createElement('div');
      const color = colors[Math.floor(Math.random() * colors.length)];
      const size  = Math.random() * 6 + 3;
      c.style.cssText = `position:absolute;width:${size}px;height:${size}px;background:${color};opacity:${Math.random()*.5+.2};left:${Math.random()*100}%;top:-10px;border-radius:${Math.random()>.5?'50%':'2px'};animation:confetti-fall ${Math.random()*8+5}s linear ${Math.random()*4}s infinite;`;
      container.appendChild(c);
    }
  }

  const styleEl = document.createElement('style');
  styleEl.textContent = `
    @keyframes twinkle { from{opacity:.1} to{opacity:.8} }
    @keyframes confetti-fall { 0%{transform:translateY(-10px) rotate(0deg);opacity:.6} 100%{transform:translateY(110vh) rotate(720deg);opacity:0} }
  `;
  document.head.appendChild(styleEl);

  function initViewer() {
    const overlay  = document.getElementById('viewerOverlay');
    const frame    = document.getElementById('viewerFrame');
    const titleEl  = document.getElementById('viewerTitle');
    const closeBtn = document.getElementById('viewerClose');

    function openViewer(embedUrl, title) {
      titleEl.textContent = title;
      frame.src = embedUrl;
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeViewer() {
      overlay.classList.remove('open');
      frame.src = '';
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.gallery-item').forEach(item => {
      item.addEventListener('click', () => openViewer(item.dataset.embed, item.dataset.caption));
    });
    document.querySelectorAll('.video-card').forEach(card => {
      card.addEventListener('click', () => openViewer(card.dataset.embed, card.dataset.title));
    });

    closeBtn.addEventListener('click', closeViewer);
    overlay.addEventListener('click', e => { if (e.target === overlay) closeViewer(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeViewer(); });
  }
</script>