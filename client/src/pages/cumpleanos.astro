<BaseLayout title="¡Feliz Cumpleaños Ania! — 24 años & 3 años VTuber">
  <div class="bday-page">
    <div class="bday-bg"></div>
    <div class="confetti-container" id="confetti"></div>

    <!-- COUNTDOWN -->
    <div class="countdown-screen" id="countdownScreen">
      <div class="hero-stars" id="cntStars"></div>
      <div class="cd-inner container">
        <div class="cd-eyebrow">
          <span class="star-icon">✦</span> Algo especial se acerca <span class="star-icon">✦</span>
        </div>
        <h1 class="cd-title">
          <span class="cd-line1">Ania</span>
          <span class="cd-line2">Starlight</span>
        </h1>
        <p class="cd-sub">{PERSON_AGE} años · {VTUBER_YEARS} años VTuber · pronto lo celebramos juntos</p>
        <div class="cd-timer">
          <div class="cd-unit"><span class="cd-num" id="cdDays">00</span><span class="cd-lbl">Días</span></div>
          <div class="cd-sep">:</div>
          <div class="cd-unit"><span class="cd-num" id="cdHours">00</span><span class="cd-lbl">Horas</span></div>
          <div class="cd-sep">:</div>
          <div class="cd-unit"><span class="cd-num" id="cdMins">00</span><span class="cd-lbl">Min</span></div>
          <div class="cd-sep">:</div>
          <div class="cd-unit"><span class="cd-num" id="cdSecs">00</span><span class="cd-lbl">Seg</span></div>
        </div>
        <div class="cd-cake">
          <div class="candles">
            {Array.from({length: 5}).map((_, i) => (
              <div class="candle" style={`animation-delay:${i * 0.2}s`}><div class="flame"></div></div>
            ))}
          </div>
          <div class="cake-top-cd"></div>
          <div class="cake-mid-cd"></div>
          <div class="cake-bot-cd"></div>
        </div>
        <p class="cd-hint"><button class="cd-unlock-btn" id="cdUnlockBtn">Acceder Ahora ✦</button></p>
      </div>
    </div>

    <!-- CONTENIDO PRINCIPAL -->
    <div class="bday-content" id="bdayContent" style="display:none">

      <!-- HERO -->
      <section class="bday-hero">
        <div class="hero-stars" id="heroStars"></div>
        <div class="bday-hero-inner container">
          <div class="bday-eyebrow">
            <span class="star-icon">✦</span>
            <span>{VTUBER_YEARS} años como VTuber</span>
            <span class="sep">·</span>
            <span>{PERSON_AGE} años de vida</span>
            <span class="star-icon">✦</span>
          </div>
          <h1 class="bday-title">
            <span class="bday-line1">¡Feliz</span>
            <span class="bday-line2">Cumpleaños</span>
            <span class="bday-line3">Ania!</span>
          </h1>
          <div class="bday-cake">
            <div class="cake-body">
              <div class="cake-top">
                <div class="candles">
                  {Array.from({length: 5}).map((_, i) => (
                    <div class="candle" style={`animation-delay:${i * 0.2}s`}><div class="flame"></div></div>
                  ))}
                </div>
              </div>
              <div class="cake-mid"></div>
              <div class="cake-bot"></div>
            </div>
          </div>
          <div class="bday-stats">
            <div class="bday-stat"><span class="bday-stat-num">{PERSON_AGE}</span><span class="bday-stat-lbl">Años de vida</span></div>
            <div class="bday-stat-div">✦</div>
            <div class="bday-stat"><span class="bday-stat-num">{VTUBER_YEARS}</span><span class="bday-stat-lbl">Años VTuber</span></div>
            <div class="bday-stat-div">✦</div>
            <div class="bday-stat"><span class="bday-stat-num">∞</span><span class="bday-stat-lbl">Amor de la comunidad</span></div>
          </div>
        </div>
      </section>

      <!-- CARTA -->
      <section class="section-pad bday-section">
        <div class="container" style="max-width:720px">
          <div class="section-label">Mensaje especial</div>
          <h2 class="section-title">Una <span class="accent-p">carta</span> para ti</h2>
          <div class="carta-wrap">
            <div class="carta-deco-tl">✦</div><div class="carta-deco-tr">✦</div>
            <div class="carta-deco-bl">✦</div><div class="carta-deco-br">✦</div>
            <div class="carta-lines">
              {CARTA.split('\n').map(line => <p class="carta-line">{line || '\u00a0'}</p>)}
            </div>
            <div class="carta-firma">— Con cariño, los StarHornys/Anitos/Nucitos/Nudistas 💜</div>
          </div>
        </div>
      </section>

      <!-- ══ 1. GALERÍA DE RECUERDOS ══ -->
      <section class="section-pad bday-section">
        <div class="container">
          <div class="section-label">Momentos</div>
          <h2 class="section-title">Galería <span class="accent-c">de recuerdos</span></h2>
          {GALLERY.length > 0 ? (
            <div class="gallery-grid">
              {GALLERY.map((img, i) => (
                <div class={`gallery-item ${i === 0 ? 'gallery-featured' : ''}`} data-embed={getDriveEmbed(img.driveUrl)} data-caption={img.caption}>
                  <img src={getDriveThumbnail(img.driveUrl)} alt={img.caption} loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                  <div class="img-fallback" style="display:none">📸</div>
                  <div class="gallery-overlay">
                    <span class="gallery-caption">{img.caption}</span>
                    <div class="gallery-play">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M15 3h6v6M10 14L21 3M21 16v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"/></svg>
                      Ver imagen
                    </div>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="placeholder-grid">
              {Array.from({length: 6}).map((_, i) => (
                <div class="placeholder-card"><span class="placeholder-icon">📸</span><span class="placeholder-text">Foto {i + 1}</span></div>
              ))}
              <p class="placeholder-hint">✏️ Staff: agrega links de Drive en el array <code>GALLERY</code>.</p>
            </div>
          )}
        </div>
      </section>

      <!-- ══ 2. IMÁGENES DE CUMPLEAÑOS ══ -->
      <section class="section-pad bday-section">
        <div class="container">
          <div class="section-label">🎂 Especial cumpleaños</div>
          <h2 class="section-title">Imágenes <span class="accent-p">de cumpleaños</span></h2>
