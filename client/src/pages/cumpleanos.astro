  .cd-eyebrow { font-family: 'Orbitron', sans-serif; font-size: .72rem; letter-spacing: .25em; color: var(--cyan); text-transform: uppercase; display: flex; align-items: center; gap: 12px; }
  .star-icon  { color: var(--pink); animation: spin-slow 6s linear infinite; display: inline-block; }
  @keyframes spin-slow { to { transform: rotate(360deg); } }
  .cd-title { font-family: 'Orbitron', sans-serif; font-weight: 900; line-height: 1; }
  .cd-line1 { display: block; font-size: clamp(3rem, 8vw, 6rem); color: #fff; }
  .cd-line2 { display: block; font-size: clamp(3.5rem, 10vw, 8rem); background: linear-gradient(90deg, var(--cyan), var(--magenta)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; filter: drop-shadow(0 0 30px rgba(0,245,255,.3)); }
  .cd-sub   { font-family: 'Orbitron', sans-serif; font-size: .72rem; letter-spacing: .18em; color: var(--text-dim); text-transform: uppercase; }
  .cd-timer { display: flex; align-items: center; gap: 8px; }
  .cd-unit  { display: flex; flex-direction: column; align-items: center; gap: 6px; background: rgba(0,245,255,.06); border: 1px solid rgba(0,245,255,.2); border-radius: 12px; padding: 20px 28px; min-width: 90px; }
  .cd-num   { font-family: 'Orbitron', sans-serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; color: #fff; line-height: 1; }
  .cd-lbl   { font-family: 'Orbitron', sans-serif; font-size: .6rem; letter-spacing: .2em; color: var(--text-dim); text-transform: uppercase; }
  .cd-sep   { font-family: 'Orbitron', sans-serif; font-size: 2.5rem; color: var(--cyan); font-weight: 900; animation: blink-sep 1s step-end infinite; margin-bottom: 18px; }
  @keyframes blink-sep { 0%,100%{opacity:1} 50%{opacity:.2} }
  .cd-cake    { display: flex; flex-direction: column; align-items: center; animation: float-cake 3s ease-in-out infinite; }
  @keyframes float-cake { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
  .cake-top-cd { width: 100px; height: 40px; background: linear-gradient(135deg, #2d0a4e, #1a0630); border-radius: 8px 8px 0 0; border: 1px solid rgba(212,0,255,.3); border-bottom: none; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 4px; }
  .cake-mid-cd { width: 130px; height: 45px; background: linear-gradient(135deg, #1a0a3a, #0d0620); border: 1px solid rgba(0,245,255,.2); border-top: none; border-bottom: none; }
  .cake-bot-cd { width: 160px; height: 50px; background: linear-gradient(135deg, #0d0620, #060310); border: 1px solid rgba(255,45,138,.25); border-top: none; border-radius: 0 0 10px 10px; }
  .cd-hint       { font-size: .82rem; color: var(--text-dim); }
  .cd-unlock-btn { background: transparent; border: none; color: var(--cyan); font-family: 'Orbitron', sans-serif; font-size: .72rem; letter-spacing: .1em; cursor: pointer; text-decoration: underline; padding: 0; transition: color .2s; }
  .cd-unlock-btn:hover { color: var(--pink); }

  /* Candles */
  .candles { display: flex; justify-content: center; gap: 10px; }
  .candle  { width: 7px; height: 20px; background: linear-gradient(var(--cyan), var(--magenta)); border-radius: 3px; position: relative; }
  .flame   { width: 9px; height: 12px; background: radial-gradient(ellipse at 50% 80%, #fff 0%, #ffee00 30%, #ff8c00 60%, transparent 100%); border-radius: 50% 50% 30% 30%; position: absolute; top: -11px; left: -1px; animation: flicker .6s ease-in-out infinite alternate; }
  @keyframes flicker { 0%{transform:scaleY(1) rotate(-3deg)} 100%{transform:scaleY(.9) rotate(3deg)} }

  /* ══ HERO ════════════════════════════════════════════════════════ */
  .bday-hero       { position: relative; z-index: 2; min-height: 95vh; display: flex; align-items: center; padding: 80px 0 60px; border-bottom: 1px solid rgba(0,245,255,.12); }
  .bday-hero-inner { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 32px; }
  .bday-eyebrow    { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; justify-content: center; font-family: 'Orbitron', sans-serif; font-size: .72rem; letter-spacing: .25em; color: var(--cyan); text-transform: uppercase; }
  .sep { color: var(--text-dim); }
  .bday-title  { display: flex; flex-direction: column; align-items: center; font-family: 'Orbitron', sans-serif; font-weight: 900; line-height: 1; animation: hero-in 1s ease both; }
  @keyframes hero-in { from{opacity:0;transform:translateY(40px)} to{opacity:1;transform:none} }
  .bday-line1  { font-size: clamp(2rem, 5vw, 4rem); color: #fff; }
  .bday-line2  { font-size: clamp(3rem, 8vw, 7rem); background: linear-gradient(90deg, var(--cyan), var(--magenta)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; filter: drop-shadow(0 0 30px rgba(0,245,255,.3)); }
  .bday-line3  { font-size: clamp(3.5rem, 10vw, 9rem); color: #fff; text-shadow: 0 0 40px rgba(255,45,138,.4); }
  .bday-cake   { animation: float-cake 3s ease-in-out infinite; }
  .cake-body   { display: flex; flex-direction: column; align-items: center; }
  .cake-top    { width: 120px; background: linear-gradient(135deg, #2d0a4e, #1a0630); border-radius: 8px 8px 0 0; padding: 10px 0 0; border: 1px solid rgba(212,0,255,.3); border-bottom: none; }
  .cake-mid    { width: 150px; height: 50px; background: linear-gradient(135deg, #1a0a3a, #0d0620); border: 1px solid rgba(0,245,255,.2); border-top: none; border-bottom: none; position: relative; }
  .cake-mid::after { content: '✦ ✦ ✦'; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); color: var(--cyan); font-size: .7rem; letter-spacing: .2em; }
  .cake-bot    { width: 180px; height: 55px; background: linear-gradient(135deg, #0d0620, #060310); border: 1px solid rgba(255,45,138,.25); border-top: none; border-radius: 0 0 10px 10px; position: relative; }
  .cake-bot::after { content: '♡ ♡ ♡'; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); color: var(--pink); font-size: .75rem; letter-spacing: .3em; }
  .bday-stats    { display: flex; align-items: center; gap: 32px; flex-wrap: wrap; justify-content: center; }
  .bday-stat     { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .bday-stat-num { font-family: 'Orbitron', sans-serif; font-size: 2.2rem; font-weight: 900; color: #fff; line-height: 1; }
  .bday-stat-lbl { font-family: 'Orbitron', sans-serif; font-size: .6rem; letter-spacing: .18em; color: var(--text-dim); text-transform: uppercase; }
  .bday-stat-div { font-size: 1.2rem; color: var(--pink); animation: pulse-star 2s ease infinite; }
  @keyframes pulse-star { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.8)} }

  /* ══ CARTA ════════════════════════════════════════════════════════ */
  .carta-wrap  { position: relative; background: linear-gradient(135deg, rgba(212,0,255,.06), rgba(0,245,255,.04)); border: 1px solid rgba(212,0,255,.25); border-radius: 16px; padding: 48px 40px; box-shadow: 0 0 60px rgba(212,0,255,.08); }
  .carta-deco-tl,.carta-deco-tr,.carta-deco-bl,.carta-deco-br { position: absolute; font-size: 1.2rem; color: var(--pink); opacity: .6; }
  .carta-deco-tl { top:14px; left:18px; } .carta-deco-tr { top:14px; right:18px; }
  .carta-deco-bl { bottom:14px; left:18px; } .carta-deco-br { bottom:14px; right:18px; }
  .carta-lines { display: flex; flex-direction: column; gap: 16px; }
  .carta-line  { font-size: 1.05rem; line-height: 1.8; color: rgba(255,255,255,.85); margin: 0; font-style: italic; }
  .carta-firma { margin-top: 28px; text-align: right; font-family: 'Orbitron', sans-serif; font-size: .75rem; letter-spacing: .1em; color: var(--magenta); }

  /* ══ GALERÍAS ════════════════════════════════════════════════════ */
  .gallery-grid    { display: grid; grid-template-columns: repeat(3,1fr); grid-auto-rows: 220px; gap: 12px; }
  .gallery-featured{ grid-column: span 2; grid-row: span 2; }
  .gallery-item    { border-radius: 10px; overflow: hidden; position: relative; cursor: pointer; border: 1px solid var(--border-c); transition: transform .3s, box-shadow .3s; background: rgba(0,245,255,.03); }
  .gallery-item:hover { transform: scale(1.02); box-shadow: var(--glow-c); border-color: var(--cyan); }
  .gallery-item img   { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; display: block; }
