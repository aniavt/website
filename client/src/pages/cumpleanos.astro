            </div>
          )}
        </div>
      </section>

      <!-- ══ 4. VIDEOS DE CUMPLEAÑOS ══ -->
      <section class="section-pad bday-section">
        <div class="container">
          <div class="section-label">🎂 Especial cumpleaños</div>
          <h2 class="section-title">Videos <span class="accent-c">de cumpleaños</span></h2>
          {BDAY_VIDEOS.length > 0 ? (
            <div class="videos-grid">
              {BDAY_VIDEOS.map((vid) => (
                <div class="video-card bday-video-card" data-embed={getDriveEmbed(vid.driveUrl)} data-title={vid.title}>
                  <div class="video-thumb">
                    <img src={getDriveThumbnail(vid.driveUrl)} alt={vid.title} loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
