          <span class="viewer-title" id="viewerTitle"></span>
          <button class="viewer-close" id="viewerClose">✕</button>
        </div>
        <div class="viewer-frame-wrap">
          <iframe id="viewerFrame" src="" allow="autoplay; fullscreen" allowfullscreen frameborder="0"></iframe>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  /* ══ BASE ═══════════════════════════════════════════════════════ */
  .bday-page    { min-height: 100vh; padding-top: var(--nav-h); position: relative; overflow-x: hidden; }
  .bday-bg      { position: fixed; inset: 0; z-index: 0; pointer-events: none; background: radial-gradient(ellipse 70% 50% at 80% 20%, rgba(212,0,255,.07) 0%, transparent 55%), radial-gradient(ellipse 50% 50% at 10% 80%, rgba(0,245,255,.05) 0%, transparent 50%); }
  .confetti-container { position: fixed; inset: 0; z-index: 1; pointer-events: none; overflow: hidden; }
  .bday-section { position: relative; z-index: 2; }
  .hero-stars   { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }

  /* ══ COUNTDOWN ══════════════════════════════════════════════════ */
  .countdown-screen { position: relative; z-index: 2; min-height: calc(100vh - var(--nav-h)); display: flex; align-items: center; justify-content: center; }
