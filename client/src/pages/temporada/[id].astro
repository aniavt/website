---
// src/pages/temporada/[id].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { animes } from '../../data/animes';

export function getStaticPaths() {
  return animes.map((anime) => ({
    params: { id: String(anime.id) },
    props:  { anime },
  }));
}

const { anime } = Astro.props;

const statusLabel = {
  watching:  { text: 'Viendo',      class: 'status-watching'  },
  completed: { text: 'Completado',  class: 'status-completed' },
  upcoming:  { text: 'Próximamente',class: 'status-upcoming'  },
};
const st = statusLabel[anime.status];
---

<BaseLayout title={`${anime.title} — Ania Starlight`}>
  <div class="detail-page">

    <!-- ── HERO del anime ── -->
    <div class="anime-hero">
      <!-- Fondo con la imagen de portada si existe -->
      {anime.coverImage && (
        <div class="anime-hero-bg" style={`background-image: url(${anime.coverImage})`}></div>
      )}
      <div class="anime-hero-overlay"></div>

      <div class="container anime-hero-content">
        <!-- Botón volver -->
        <a href="/temporada" class="back-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M5 12l7-7M5 12l7 7"/>
          </svg>
          Volver a Temporada
        </a>

        <div class="anime-hero-grid">
          <!-- Portada -->
          <div class="anime-cover-wrap">
            <div class="anime-cover">
              {anime.coverImage
                ? <img src={anime.coverImage} alt={anime.title} />
                : <span class="cover-emoji">{anime.emoji}</span>
              }
              <div class="cover-glow"></div>
            </div>
          </div>

          <!-- Info -->
          <div class="anime-info">
            <div class="anime-meta-top">
              <span class={`anime-status ${st.class}`}>{st.text}</span>
              <span class="anime-genre">{anime.genre}</span>
            </div>

            <h1 class="anime-title">{anime.title}</h1>

            {anime.description && (
              <p class="anime-desc">{anime.description}</p>
            )}

            <div class="anime-stats">
              <div class="astat">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--pink)" stroke-width="2">
                  <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2M8 7V5a2 2 0 0 0-4 0v2"/>
                </svg>
                <div>
                  <span class="astat-num">{anime.episodes.length}</span>
                  <span class="astat-lbl">Total episodios</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── LISTA DE EPISODIOS ── -->
    <section class="episodes-section">
      <div class="container">
        <div class="ep-section-header">
          <h2 class="ep-section-title">
            <span class="ep-title-bar"></span>
            EPISODIOS
          </h2>
        </div>

        {anime.episodes.length > 0 ? (
          <div class="ep-grid">
            {anime.episodes.map((ep, i) => (
              <a
                href={ep.url}
                target="_blank"
                rel="noopener"
                class="ep-card"
              >
                <!-- Thumbnail (si hay imagen usa esa, si no muestra número) -->
                <div class="ep-thumb">
                  {ep.thumbnail
                    ? <img src={ep.thumbnail} alt={ep.label} />
                    : <div class="ep-thumb-placeholder">
                        <span class="ep-num-big">{String(i + 1).padStart(2, '0')}</span>
                      </div>
                  }
                  <div class="ep-thumb-overlay">
                    <div class="play-circle">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
                        <polygon points="5,3 19,12 5,21"/>
                      </svg>
                    </div>
                  </div>
                  {ep.duration && <span class="ep-duration">{ep.duration}</span>}
                </div>

                <div class="ep-info">
                  <div class="ep-label-row">
                    <span class="ep-badge">{ep.num}</span>
                    {ep.isNew && <span class="ep-new">NUEVO</span>}
                  </div>
                  <h3 class="ep-title">{ep.label}</h3>
                  {ep.date && <span class="ep-date">{ep.date}</span>}
                </div>

                <div class="ep-arrow">↗</div>
              </a>
            ))}
          </div>
        ) : (
          <div class="no-episodes">
            <span>⏳</span>
            <p>Próximamente — aún no hay episodios disponibles.</p>
          </div>
        )}
      </div>
    </section>

  </div>
</BaseLayout>

<style>
.detail-page { min-height: 100vh; padding-top: var(--nav-h); }

/* ── Hero ── */
.anime-hero {
  position: relative; overflow: hidden;
  padding: 60px 0 48px; min-height: 360px;
  display: flex; align-items: flex-end;
}
.anime-hero-bg {
  position: absolute; inset: 0;
  background-size: cover; background-position: center top;
  filter: blur(18px) brightness(.35) saturate(1.4);
  transform: scale(1.1);
}
.anime-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(4,6,14,.4) 0%,
    rgba(4,6,14,.7) 60%,
    var(--dark)     100%
  );
}
.anime-hero-content { position: relative; z-index: 2; width: 100%; }

.back-btn {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: 'Orbitron', sans-serif; font-size: .68rem;
  letter-spacing: .15em; color: var(--text-dim);
  margin-bottom: 32px; transition: color .2s;
  text-transform: uppercase;
}
.back-btn:hover { color: var(--cyan); }

.anime-hero-grid {
  display: grid; grid-template-columns: 220px 1fr;
  gap: 40px; align-items: flex-end;
}

/* Cover */
.anime-cover-wrap { position: relative; }
.anime-cover {
  width: 220px; aspect-ratio: .68;
  border-radius: 12px; overflow: hidden;
  border: 2px solid var(--border-c);
  position: relative;
  box-shadow: 0 20px 60px rgba(0,0,0,.6), var(--glow-c);
}
.anime-cover img { width: 100%; height: 100%; object-fit: cover; }
.cover-emoji {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 5rem; opacity: .4;
  background: linear-gradient(135deg, rgba(0,245,255,.06), rgba(212,0,255,.06));
}
.cover-glow {
  position: absolute; bottom: -20px; left: 50%;
  transform: translateX(-50%);
  width: 80%; height: 40px;
  background: radial-gradient(ellipse, rgba(0,245,255,.3), transparent 70%);
  filter: blur(12px); pointer-events: none;
}

/* Info */
.anime-meta-top { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; }
.anime-genre {
  font-family: 'Orbitron', sans-serif; font-size: .65rem;
  letter-spacing: .2em; color: var(--text-dim); text-transform: uppercase;
}
.anime-title {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(1.8rem, 3.5vw, 3rem); font-weight: 900;
  color: #fff; line-height: 1.1; margin-bottom: 20px;
  letter-spacing: .03em;
}
.anime-desc {
  font-size: .97rem; color: var(--text-dim); line-height: 1.75;
  max-width: 560px; margin-bottom: 28px;
}
.anime-stats { display: flex; gap: 24px; flex-wrap: wrap; }
.astat {
  display: flex; align-items: center; gap: 12px;
  background: rgba(255,45,138,.07); border: 1px solid var(--border-p);
  border-radius: 10px; padding: 14px 20px;
}
.astat-num  { display: block; font-family: 'Orbitron', sans-serif; font-size: 1.6rem; font-weight: 900; color: var(--pink); line-height: 1; }
.astat-lbl  { display: block; font-size: .68rem; letter-spacing: .15em; color: var(--text-dim); text-transform: uppercase; margin-top: 2px; }

/* ── Episodes ── */
.episodes-section { padding: 48px 0 80px; }
.ep-section-header { margin-bottom: 28px; }
.ep-section-title {
  font-family: 'Orbitron', sans-serif; font-size: 1rem;
  font-weight: 900; letter-spacing: .2em; color: #fff;
  display: flex; align-items: center; gap: 14px;
}
.ep-title-bar {
  display: block; width: 4px; height: 24px; border-radius: 2px;
  background: linear-gradient(var(--cyan), var(--pink));
}

.ep-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
}

.ep-card {
  display: flex; flex-direction: column;
  background: var(--card); border: 1px solid var(--border-c);
  border-radius: var(--radius); overflow: hidden;
  text-decoration: none; color: var(--text);
  transition: transform .3s, border-color .3s, box-shadow .3s;
  position: relative;
}
.ep-card:hover {
  transform: translateY(-5px);
  border-color: var(--cyan); box-shadow: var(--glow-c);
}

.ep-thumb {
  aspect-ratio: 16/9; position: relative; overflow: hidden;
  background: linear-gradient(135deg, rgba(0,245,255,.05), rgba(212,0,255,.05));
}
.ep-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
.ep-card:hover .ep-thumb img { transform: scale(1.05); }
.ep-thumb-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
}
.ep-num-big {
  font-family: 'Orbitron', sans-serif; font-size: 3rem;
  font-weight: 900; color: rgba(0,245,255,.15);
}
.ep-thumb-overlay {
  position: absolute; inset: 0;
  background: rgba(4,6,14,.4);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity .3s;
}
.ep-card:hover .ep-thumb-overlay { opacity: 1; }
.play-circle {
  width: 52px; height: 52px; border-radius: 50%;
  background: rgba(0,245,255,.2); border: 2px solid var(--cyan);
  display: flex; align-items: center; justify-content: center;
  box-shadow: var(--glow-c);
}
.ep-duration {
  position: absolute; bottom: 8px; right: 10px;
  font-family: 'Orbitron', sans-serif; font-size: .6rem;
  background: rgba(4,6,14,.8); padding: 3px 8px; border-radius: 4px;
  color: #fff; letter-spacing: .08em;
}

.ep-info { padding: 14px 16px; flex: 1; }
.ep-label-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.ep-badge {
  font-family: 'Orbitron', sans-serif; font-size: .6rem;
  letter-spacing: .12em; color: var(--cyan);
  background: rgba(0,245,255,.08); border: 1px solid rgba(0,245,255,.2);
  padding: 2px 8px; border-radius: 4px;
}
.ep-new {
  font-family: 'Orbitron', sans-serif; font-size: .55rem;
  letter-spacing: .12em; color: var(--pink);
  background: rgba(255,45,138,.1); border: 1px solid var(--border-p);
  padding: 2px 8px; border-radius: 4px;
  animation: pulse-new 2s ease infinite;
}
@keyframes pulse-new { 0%,100%{opacity:1} 50%{opacity:.5} }
.ep-title { font-size: .9rem; font-weight: 600; color: #fff; margin-bottom: 4px; line-height: 1.3; }
.ep-date  { font-size: .72rem; color: var(--text-dim); }

.ep-arrow {
  position: absolute; top: 12px; right: 14px;
  font-size: 1rem; color: var(--text-dim);
  transition: color .2s, transform .2s;
}
.ep-card:hover .ep-arrow { color: var(--cyan); transform: translate(2px, -2px); }

/* No episodes */
.no-episodes {
  display: flex; flex-direction: column; align-items: center;
  gap: 16px; padding: 60px 0; color: var(--text-dim); text-align: center;
}
.no-episodes span { font-size: 3rem; }
.no-episodes p { font-size: 1rem; }

/* Responsive */
@media(max-width: 700px) {
  .anime-hero-grid { grid-template-columns: 1fr; }
  .anime-cover { width: 160px; }
  .ep-grid { grid-template-columns: 1fr; }
}
</style>
