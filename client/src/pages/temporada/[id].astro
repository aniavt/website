---
// src/pages/temporada/[id].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { animes } from '../../data/animes';

export function getStaticPaths() {
  return animes.map((anime) => ({
    params: { id: String(anime.id) },
    props:  { anime },
  }));
}

const { anime } = Astro.props;

const statusLabel = {
  watching:  { text: 'Viendo',       class: 'status-watching'  },
  completed: { text: 'Completado',   class: 'status-completed' },
  upcoming:  { text: 'Próximamente', class: 'status-upcoming'  },
};
const st = statusLabel[anime.status];
---

<BaseLayout title={`${anime.title} — Ania Starlight`}>
  <div class="detail-page">

    <!-- ── HERO ── -->
    <div class="anime-hero">
      {anime.coverImage && (
        <div class="anime-hero-bg" style={`background-image: url(${anime.coverImage})`}></div>
      )}
      <div class="anime-hero-overlay"></div>

      <div class="container anime-hero-content">
        <a href="/temporada" class="back-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M5 12l7-7M5 12l7 7"/>
          </svg>
          Volver a Temporada
        </a>

        <div class="anime-hero-grid">
          <div class="anime-cover-wrap">
            <div class="anime-cover">
              {anime.image
                ? <img src={anime.image} alt={anime.title} />
                : <span class="cover-emoji">{anime.emoji}</span>
              }
              <div class="cover-glow"></div>
            </div>
          </div>

          <div class="anime-info">
            <div class="anime-meta-top">
              <span class={`anime-status ${st.class}`}>{st.text}</span>
              <span class="anime-genre">{anime.genre}</span>
            </div>
            <h1 class="anime-title">{anime.title}</h1>
            {anime.description && <p class="anime-desc">{anime.description}</p>}
            <div class="anime-stats">
              <div class="astat">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--pink)" stroke-width="2">
                  <rect x="2" y="7" width="20" height="14" rx="2"/>
                  <path d="M16 7V5a2 2 0 0 0-4 0v2M8 7V5a2 2 0 0 0-4 0v2"/>
                </svg>
                <div>
                  <span class="astat-num">{anime.episodes.length}</span>
                  <span class="astat-lbl">Total episodios</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── PLAYER (se muestra al seleccionar episodio) ── -->
    <div class="player-section" id="playerSection" style="display:none">
      <div class="container">
        <div class="player-wrap">
          <div class="player-header">
            <div class="player-info">
              <span class="player-ep-badge" id="playerBadge">EP 01</span>
              <h2 class="player-title" id="playerTitle">Cargando...</h2>
            </div>
            <button class="player-close" id="playerClose" title="Cerrar reproductor">✕</button>
          </div>
          <div class="player-container">
            <iframe
              id="playerFrame"
              src=""
              allow="autoplay; fullscreen"
              allowfullscreen
              frameborder="0"
            ></iframe>
            <!-- Fallback si el iframe no carga -->
            <div class="player-fallback" id="playerFallback">
              <p>El video no pudo cargarse en el reproductor.</p>
              <a id="playerFallbackLink" href="#" target="_blank" class="btn btn-cyan">
                Abrir en nueva pestaña ↗
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── LISTA DE EPISODIOS ── -->
    <section class="episodes-section">
      <div class="container">
        <h2 class="ep-section-title">
          <span class="ep-title-bar"></span>
          EPISODIOS
        </h2>

        {anime.episodes.length > 0 ? (
          <div class="ep-grid">
            {anime.episodes.map((ep, i) => (
              <div
                class="ep-card"
                data-url={ep.url}
                data-label={ep.label}
                data-num={ep.num}
              >
                <div class="ep-thumb">
                  {ep.thumbnail
                    ? <img src={ep.thumbnail} alt={ep.label} loading="lazy" />
                    : <div class="ep-thumb-placeholder">
                        <span class="ep-num-big">{String(i + 1).padStart(2, '0')}</span>
                      </div>
                  }
                  <div class="ep-thumb-overlay">
                    <div class="play-circle">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
                        <polygon points="5,3 19,12 5,21"/>
                      </svg>
                    </div>
                  </div>
                  {ep.duration && <span class="ep-duration">{ep.duration}</span>}
                </div>

                <div class="ep-info">
                  <div class="ep-label-row">
                    <span class="ep-badge">{ep.num}</span>
                    {ep.isNew && <span class="ep-new">NUEVO</span>}
                  </div>
                  <h3 class="ep-title">{ep.label}</h3>
                  {ep.date && <span class="ep-date">{ep.date}</span>}
                </div>

                <div class="ep-arrow">▶</div>
              </div>
            ))}
          </div>
        ) : (
          <div class="no-episodes">
            <span>⏳</span>
            <p>Próximamente — aún no hay episodios disponibles.</p>
          </div>
        )}
      </div>
    </section>

  </div>
</BaseLayout>

<style>
.detail-page { min-height: 100vh; padding-top: var(--nav-h); }

/* ── Hero ── */
.anime-hero {
  position: relative; overflow: hidden;
  padding: 60px 0 48px; min-height: 360px;
  display: flex; align-items: flex-end;
}
.anime-hero-bg {
  position: absolute; inset: 0;
  background-size: cover; background-position: center top;
  filter: blur(18px) brightness(.35) saturate(1.4);
  transform: scale(1.1);
}
.anime-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(4,6,14,.4) 0%, rgba(4,6,14,.7) 60%, var(--dark) 100%);
}
.anime-hero-content { position: relative; z-index: 2; width: 100%; }

.back-btn {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: 'Orbitron', sans-serif; font-size: .68rem;
  letter-spacing: .15em; color: var(--text-dim);
  margin-bottom: 32px; transition: color .2s; text-transform: uppercase;
}
.back-btn:hover { color: var(--cyan); }

.anime-hero-grid { display: grid; grid-template-columns: 220px 1fr; gap: 40px; align-items: flex-end; }
.anime-cover {
  width: 220px; aspect-ratio: .68; border-radius: 12px; overflow: hidden;
  border: 2px solid var(--border-c); position: relative;
  box-shadow: 0 20px 60px rgba(0,0,0,.6), var(--glow-c);
}
.anime-cover img { width: 100%; height: 100%; object-fit: cover; }
.cover-emoji {
  width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
  font-size: 5rem; opacity: .4;
  background: linear-gradient(135deg, rgba(0,245,255,.06), rgba(212,0,255,.06));
}
.cover-glow {
  position: absolute; bottom: -20px; left: 50%; transform: translateX(-50%);
  width: 80%; height: 40px;
  background: radial-gradient(ellipse, rgba(0,245,255,.3), transparent 70%);
  filter: blur(12px); pointer-events: none;
}
.anime-meta-top { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; }
.anime-genre { font-family: 'Orbitron', sans-serif; font-size: .65rem; letter-spacing: .2em; color: var(--text-dim); text-transform: uppercase; }
.anime-title { font-family: 'Orbitron', sans-serif; font-size: clamp(1.8rem, 3.5vw, 3rem); font-weight: 900; color: #fff; line-height: 1.1; margin-bottom: 20px; }
.anime-desc  { font-size: .97rem; color: var(--text-dim); line-height: 1.75; max-width: 560px; margin-bottom: 28px; }
.anime-stats { display: flex; gap: 24px; flex-wrap: wrap; }
.astat { display: flex; align-items: center; gap: 12px; background: rgba(255,45,138,.07); border: 1px solid var(--border-p); border-radius: 10px; padding: 14px 20px; }
.astat-num { display: block; font-family: 'Orbitron', sans-serif; font-size: 1.6rem; font-weight: 900; color: var(--pink); line-height: 1; }
.astat-lbl { display: block; font-size: .68rem; letter-spacing: .15em; color: var(--text-dim); text-transform: uppercase; margin-top: 2px; }

/* ── Player ── */
.player-section {
  background: var(--dark2);
  border-top: 1px solid var(--border-c);
  border-bottom: 1px solid var(--border-c);
  padding: 28px 0;
  position: sticky; top: var(--nav-h); z-index: 100;
}
.player-wrap {
  background: var(--card); border: 1px solid var(--border-c);
  border-radius: 14px; overflow: hidden;
}
.player-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 20px;
  border-bottom: 1px solid var(--border-c);
  background: rgba(0,245,255,.03);
}
.player-info { display: flex; align-items: center; gap: 12px; }
.player-ep-badge {
  font-family: 'Orbitron', sans-serif; font-size: .65rem; letter-spacing: .15em;
  color: var(--cyan); background: rgba(0,245,255,.1);
  border: 1px solid rgba(0,245,255,.25); padding: 4px 10px; border-radius: 4px;
}
.player-title {
  font-family: 'Orbitron', sans-serif; font-size: .85rem;
  letter-spacing: .06em; color: #fff;
}
.player-close {
  width: 32px; height: 32px; border-radius: 6px;
  border: 1px solid var(--border-c); color: var(--text-dim);
  font-size: 1rem; display: flex; align-items: center; justify-content: center;
  transition: border-color .2s, color .2s; cursor: pointer; background: transparent;
}
.player-close:hover { border-color: var(--pink); color: var(--pink); }

.player-container {
  position: relative; aspect-ratio: 16/9; background: #000;
}
.player-container iframe {
  width: 100%; height: 100%; border: none; display: block;
}
.player-fallback {
  display: none;
  position: absolute; inset: 0;
  flex-direction: column; align-items: center; justify-content: center;
  gap: 16px; background: var(--dark2); color: var(--text-dim); text-align: center;
}
.player-fallback.visible { display: flex; }

/* ── Episodes ── */
.episodes-section { padding: 48px 0 80px; }
.ep-section-title {
  font-family: 'Orbitron', sans-serif; font-size: 1rem; font-weight: 900;
  letter-spacing: .2em; color: #fff; display: flex; align-items: center;
  gap: 14px; margin-bottom: 28px;
}
.ep-title-bar { display: block; width: 4px; height: 24px; border-radius: 2px; background: linear-gradient(var(--cyan), var(--pink)); }

.ep-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }

.ep-card {
  display: flex; flex-direction: column;
  background: var(--card); border: 1px solid var(--border-c);
  border-radius: var(--radius); overflow: hidden;
  cursor: pointer; color: var(--text);
  transition: transform .3s, border-color .3s, box-shadow .3s;
  position: relative;
}
.ep-card:hover        { transform: translateY(-5px); border-color: var(--cyan); box-shadow: var(--glow-c); }
.ep-card.playing      { border-color: var(--cyan); box-shadow: var(--glow-c); }
.ep-card.playing .ep-arrow { color: var(--cyan); }

.ep-thumb { aspect-ratio: 16/9; position: relative; overflow: hidden; background: linear-gradient(135deg, rgba(0,245,255,.05), rgba(212,0,255,.05)); }
.ep-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
.ep-card:hover .ep-thumb img { transform: scale(1.05); }
.ep-thumb-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
.ep-num-big { font-family: 'Orbitron', sans-serif; font-size: 3rem; font-weight: 900; color: rgba(0,245,255,.15); }
.ep-thumb-overlay { position: absolute; inset: 0; background: rgba(4,6,14,.5); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity .3s; }
.ep-card:hover .ep-thumb-overlay,
.ep-card.playing .ep-thumb-overlay { opacity: 1; }
.play-circle { width: 52px; height: 52px; border-radius: 50%; background: rgba(0,245,255,.2); border: 2px solid var(--cyan); display: flex; align-items: center; justify-content: center; box-shadow: var(--glow-c); }
.ep-duration { position: absolute; bottom: 8px; right: 10px; font-family: 'Orbitron', sans-serif; font-size: .6rem; background: rgba(4,6,14,.8); padding: 3px 8px; border-radius: 4px; color: #fff; }

.ep-info { padding: 14px 16px; flex: 1; }
.ep-label-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.ep-badge { font-family: 'Orbitron', sans-serif; font-size: .6rem; letter-spacing: .12em; color: var(--cyan); background: rgba(0,245,255,.08); border: 1px solid rgba(0,245,255,.2); padding: 2px 8px; border-radius: 4px; }
.ep-new { font-family: 'Orbitron', sans-serif; font-size: .55rem; letter-spacing: .12em; color: var(--pink); background: rgba(255,45,138,.1); border: 1px solid var(--border-p); padding: 2px 8px; border-radius: 4px; animation: pulse-new 2s ease infinite; }
@keyframes pulse-new { 0%,100%{opacity:1} 50%{opacity:.5} }
.ep-title { font-size: .9rem; font-weight: 600; color: #fff; margin-bottom: 4px; line-height: 1.3; }
.ep-date  { font-size: .72rem; color: var(--text-dim); }
.ep-arrow { position: absolute; bottom: 14px; right: 14px; font-size: .9rem; color: var(--text-dim); transition: color .2s; }

.no-episodes { display: flex; flex-direction: column; align-items: center; gap: 16px; padding: 60px 0; color: var(--text-dim); text-align: center; }
.no-episodes span { font-size: 3rem; }

@media(max-width: 700px) {
  .anime-hero-grid { grid-template-columns: 1fr; }
  .anime-cover { width: 160px; }
  .ep-grid { grid-template-columns: 1fr; }
  .player-section { position: static; }
}
</style>

<script>
  // ── Convierte cualquier URL de Drive/YouTube a embed ─────────────
  function toEmbedUrl(url: string): string | null {
    // Google Drive: https://drive.google.com/file/d/FILE_ID/view
    const driveMatch = url.match(/drive\.google\.com\/file\/d\/([^/]+)/);
    if (driveMatch) {
      return `https://drive.google.com/file/d/${driveMatch[1]}/preview`;
    }

    // Google Drive compartido: https://drive.google.com/open?id=FILE_ID
    const driveOpen = url.match(/drive\.google\.com\/open\?id=([^&]+)/);
    if (driveOpen) {
      return `https://drive.google.com/file/d/${driveOpen[1]}/preview`;
    }

    // YouTube watch: https://www.youtube.com/watch?v=VIDEO_ID
    const ytWatch = url.match(/youtube\.com\/watch\?v=([^&]+)/);
    if (ytWatch) {
      return `https://www.youtube.com/embed/${ytWatch[1]}?autoplay=1`;
    }

    // YouTube short: https://youtu.be/VIDEO_ID
    const ytShort = url.match(/youtu\.be\/([^?]+)/);
    if (ytShort) {
      return `https://www.youtube.com/embed/${ytShort[1]}?autoplay=1`;
    }

    // URL directa de video (.mp4, etc.) — la devuelve tal cual
    if (url.match(/\.(mp4|webm|mkv)/i)) {
      return url;
    }

    return null;
  }

  // ── Referencias DOM ──────────────────────────────────────────────
  const playerSection  = document.getElementById('playerSection')!;
  const playerFrame    = document.getElementById('playerFrame') as HTMLIFrameElement;
  const playerTitle    = document.getElementById('playerTitle')!;
  const playerBadge    = document.getElementById('playerBadge')!;
  const playerClose    = document.getElementById('playerClose')!;
  const playerFallback = document.getElementById('playerFallback')!;
  const playerFallbackLink = document.getElementById('playerFallbackLink') as HTMLAnchorElement;

  let currentCard: HTMLElement | null = null;

  // ── Click en episodio ────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.ep-card').forEach((card) => {
    card.addEventListener('click', () => {
      const url   = card.dataset.url   ?? '';
      const label = card.dataset.label ?? '';
      const num   = card.dataset.num   ?? '';

      const embedUrl = toEmbedUrl(url);

      // Quitar .playing del anterior
      currentCard?.classList.remove('playing');
      card.classList.add('playing');
      currentCard = card;

      // Actualizar header del player
      playerBadge.textContent = num;
      playerTitle.textContent = label;

      if (embedUrl) {
        playerFrame.src = embedUrl;
        playerFrame.style.display = 'block';
        playerFallback.classList.remove('visible');
      } else {
        // No se pudo convertir → mostrar fallback con link
        playerFrame.src = '';
        playerFrame.style.display = 'none';
        playerFallbackLink.href = url;
        playerFallback.classList.add('visible');
      }

      // Mostrar player y hacer scroll hasta él
      playerSection.style.display = 'block';
      playerSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // ── Cerrar player ────────────────────────────────────────────────
  playerClose.addEventListener('click', () => {
    playerSection.style.display = 'none';
    playerFrame.src = '';
    currentCard?.classList.remove('playing');
    currentCard = null;
  });
</script>
