---
// src/components/AnimeCard.astro
import { type AnimeDto, slugify } from "../lib/anime";

interface Props {
    anime: AnimeDto;
}
const { anime } = Astro.props;

const statusLabel = {
    watching: "Viendo",
    completed: "Completado",
    upcoming: "Próximo",
};
---

<a href={`/temporada/${slugify(anime.title)}`} class="anime-card">
    <div class="anime-thumb">
        {
            anime.coverImageURL ? (
                <img
                    src={anime.coverImageURL}
                    alt={anime.title}
                    loading="lazy"
                    transition:name={anime.coverImageURL}
                />
            ) : (
                <span class="emoji-placeholder">📺</span>
            )
        }
        <div class={`anime-status status-${anime.status}`}>
            {statusLabel[anime.status]}
        </div>
        <div class="card-hover-overlay">
            <span class="view-label">VER EPISODIOS →</span>
        </div>
    </div>
    <div class="anime-body">
        <h3 transition:name={anime.title}>{anime.title}</h3>
        <div class="meta">{anime.genre}</div>
    </div>
</a>

<style>
    .anime-card {
        display: block;
        text-decoration: none;
    }

    .card-hover-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 245, 255, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s;
    }
    .anime-card:hover .card-hover-overlay {
        opacity: 1;
    }
    .view-label {
        font-family: "Orbitron", sans-serif;
        font-size: 0.65rem;
        letter-spacing: 0.18em;
        color: var(--cyan);
        background: rgba(4, 6, 14, 0.8);
        padding: 8px 16px;
        border: 1px solid var(--cyan);
        border-radius: 4px;
        box-shadow: var(--glow-c);
    }
</style>
