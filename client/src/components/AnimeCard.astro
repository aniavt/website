---
// src/components/AnimeCard.astro
import type { Anime } from '../data/animes';

interface Props { anime: Anime; }
const { anime } = Astro.props;

const statusLabel = { watching: 'Viendo', completed: 'Completado', upcoming: 'Próximo' };
---

<!-- Card completa es clickeable → va a /temporada/[id] -->
<a href={`/temporada/${anime.id}`} class="anime-card">
  <div class="anime-thumb">
    {anime.image
      ? <img src={anime.image} alt={anime.title} loading="lazy" />
      : <span class="emoji-placeholder">{anime.emoji}</span>
    }
    <div class={`anime-status status-${anime.status}`}>
      {statusLabel[anime.status]}
    </div>
    <!-- Overlay hover -->
    <div class="card-hover-overlay">
      <span class="view-label">VER EPISODIOS →</span>
    </div>
  </div>
  <div class="anime-body">
    <h3>{anime.title}</h3>
    <div class="meta">{anime.genre}</div>
    <div class="ep-count">
      <span class="ep-num">{anime.episodes.length}</span>
      <span class="ep-lbl">episodio{anime.episodes.length !== 1 ? 's' : ''}</span>
    </div>
  </div>
</a>

<style>
  .anime-card { display: block; text-decoration: none; }

  .card-hover-overlay {
    position: absolute; inset: 0;
    background: rgba(0,245,255,.1);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity .3s;
  }
  .anime-card:hover .card-hover-overlay { opacity: 1; }
  .view-label {
    font-family: 'Orbitron', sans-serif; font-size: .65rem;
    letter-spacing: .18em; color: var(--cyan);
    background: rgba(4,6,14,.8); padding: 8px 16px;
    border: 1px solid var(--cyan); border-radius: 4px;
    box-shadow: var(--glow-c);
  }

  .ep-count {
    display: flex; align-items: baseline; gap: 5px; margin-top: 10px;
  }
  .ep-num {
    font-family: 'Orbitron', sans-serif; font-size: 1.1rem;
    font-weight: 900; color: var(--cyan);
  }
  .ep-lbl { font-size: .75rem; color: var(--text-dim); }
</style>
