---
// src/components/Navbar.astro
const navLinks = [
  { href: '/',            label: 'Inicio' },
  { href: '/temporada',   label: 'Temporada' },
  { href: '/manga',       label: 'Manga' },
  { href: '/varios',      label: 'Animes Varios' },
  { href: '/faq',         label: 'FAQ & Staff' },
  { href: '/hemeroteca',  label: 'Hemeroteca' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav id="navbar">
  <a href="/" class="nav-logo">
    <div class="nav-star"></div>
    <div>ANIA<br />STARLIGHT</div>
  </a>

  <ul>
    {navLinks.map(({ href, label }) => {
      const normalizedHref = href === '/' ? '/' : href;
      const isActive =
        href === '/'
          ? currentPath === '/' || currentPath === ''
          : currentPath.startsWith(href);
      return (
        <li>
          <a href={href} class:list={['nav-link', { active: isActive }]}>
            {label}
          </a>
        </li>
      );
    })}
  </ul>

  <!-- Mobile hamburger -->
  <button class="nav-toggle" id="navToggle" aria-label="Menú">☰</button>
</nav>

<style>
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    height: var(--nav-h);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px;
    background: rgba(4, 6, 14, 0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-c);
  }
  .nav-logo {
    display: flex; align-items: center; gap: 10px;
    font-family: 'Orbitron', sans-serif;
    font-weight: 900; font-size: 1.15rem;
    background: linear-gradient(120deg, #fff 30%, var(--cyan));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    letter-spacing: 0.04em; line-height: 1.2;
    white-space: nowrap;      /* ← evita que corte la palabra */
    overflow: visible;        /* ← permite que se vea completo */
    flex-shrink: 0;           /* ← no se achica con el navbar */
    font-size: 1rem;
  }
  .nav-star {
    width: 24px; height: 24px; flex-shrink: 0;
    background: conic-gradient(var(--cyan), var(--pink), var(--magenta), var(--cyan));
    clip-path: polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%);
    animation: star-spin 5s linear infinite;
    filter: drop-shadow(0 0 5px var(--cyan));
  }
  @keyframes star-spin { to { transform: rotate(360deg); } }

  ul { display: flex; list-style: none; gap: 2px; }
  .nav-link {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600; font-size: 0.88rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-dim);
    padding: 8px 14px; border-radius: 6px;
    transition: color 0.25s, background 0.25s;
    display: block;
  }
  .nav-link:hover,
  .nav-link.active { color: var(--cyan); background: rgba(0, 245, 255, 0.07); }

  .nav-toggle { display: none; color: var(--cyan); font-size: 1.4rem; padding: 8px; }

  @media (max-width: 900px) {
    nav { padding: 0 20px; }
    ul {
      display: none; flex-direction: column; gap: 4px;
      position: absolute; top: var(--nav-h); left: 0; right: 0;
      background: rgba(4, 6, 14, 0.98);
      padding: 16px 20px 24px;
      border-bottom: 1px solid var(--border-c);
    }
    ul.open { display: flex; }
    .nav-toggle { display: block; }
  }
</style>

<script>
  document.getElementById('navToggle')?.addEventListener('click', () => {
    document.querySelector('nav ul')?.classList.toggle('open');
  });
</script>
